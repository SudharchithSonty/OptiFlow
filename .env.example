# OptiFlow Environment Configuration

# Database (PostgreSQL - required)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/optiflow

# JWT Authentication (required - change in production)
JWT_SECRET=change-me-to-a-strong-random-secret

# Application
DEBUG=true
LOG_LEVEL=INFO

# Frontend API URL (used by Vite)
VITE_API_BASE_URL=http://localhost:8000

# Anthropic (optional - for AI agent)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (optional - for embeddings)
# OPENAI_API_KEY=sk-...
